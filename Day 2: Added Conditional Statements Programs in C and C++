#include <stdio.h>

int main() {

    // Even or Odd
    int num = 7;
    if (num % 2 == 0)
        printf("%d is Even\n", num);
    else
        printf("%d is Odd\n", num);

    // Positive, Negative, or Zero
    int n = -5;
    if (n > 0)
        printf("%d is Positive\n", n);
    else if (n < 0)
        printf("%d is Negative\n", n);
    else
        printf("Number is Zero\n");

    // Largest of Three Numbers
    int a = 10, b = 25, c = 15;
    if (a >= b && a >= c)
        printf("Largest = %d\n", a);
    else if (b >= a && b >= c)
        printf("Largest = %d\n", b);
    else
        printf("Largest = %d\n", c);

    // Leap Year Check
    int year = 2024;
    if ((year % 4 == 0 && year % 100 != 0) || year % 400 == 0)
        printf("%d is a Leap Year\n", year);
    else
        printf("%d is not a Leap Year\n", year);

    // Grade Calculator
    int marks = 85;
    if (marks >= 90)
        printf("Grade A+\n");
    else if (marks >= 80)
        printf("Grade A\n");
    else if (marks >= 70)
        printf("Grade B\n");
    else if (marks >= 60)
        printf("Grade C\n");
    else
        printf("Grade F\n");

    return 0;
}



