/* 1. Count Vowels in a String */

#include<stdio.h>
#include<conio.h>

void main()
{
    char str[100];
    int i,count=0;

    clrscr();

    printf("Enter String: ");
    gets(str);

    for(i=0;str[i]!='\0';i++)
    {
        if(str[i]=='a'||str[i]=='e'||str[i]=='i'||str[i]=='o'||str[i]=='u'||
           str[i]=='A'||str[i]=='E'||str[i]=='I'||str[i]=='O'||str[i]=='U')
            count++;
    }

    printf("Vowels = %d",count);

    getch();
}


