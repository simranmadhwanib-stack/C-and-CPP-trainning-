/* 6. Anagram Check */

#include<stdio.h>
#include<string.h>
#include<conio.h>

void main()
{
    char str1[100],str2[100];
    int i,j,flag=1;

    clrscr();

    printf("Enter First String: ");
    gets(str1);

    printf("Enter Second String: ");
    gets(str2);

    if(strlen(str1)!=strlen(str2))
        flag=0;

    for(i=0;str1[i]!='\0' && flag;i++)
    {
        for(j=0;str2[j]!='\0';j++)
        {
            if(str1[i]==str2[j])
            {
                str2[j]='*';
                break;
            }
        }

        if(str2[j]=='\0')
            flag=0;
    }

    if(flag)
        printf("Anagram");
    else
        printf("Not Anagram");

    getch();
}
