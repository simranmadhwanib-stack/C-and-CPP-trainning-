/* 3. Palindrome Check */

#include<stdio.h>
#include<string.h>
#include<conio.h>

void main()
{
    char str[100],rev[100];

    clrscr();

    printf("Enter String: ");
    gets(str);

    strcpy(rev,str);
    strrev(rev);

    if(strcmp(str,rev)==0)
        printf("Palindrome");
    else
        printf("Not Palindrome");

    getch();
}


