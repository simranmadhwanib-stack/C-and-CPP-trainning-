#include <stdio.h>

int main() {

    printf("Hello, World!\n");

    printf("My Name is Simran\n");

    int a = 10, b = 20;
    printf("Sum = %d\n", a + b);

    int length = 10, breadth = 5;
    printf("Area of Rectangle = %d\n", length * breadth);

    float p = 1000, r = 5, t = 2;
    float si = (p * r * t) / 100;
    printf("Simple Interest = %.2f\n", si);

    float c = 25;
